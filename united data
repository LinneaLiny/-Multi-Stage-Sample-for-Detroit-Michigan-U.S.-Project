  rr        = as.numeric(resp_rate)) %>%
  mutate(n_selected = ceiling(n_resp / rr))

print(target_table)

total_n <- sum(target_table$n_selected)   # S+ = 2156
m_bar   <- total_n / n_psu                # n_bar = 53.9

cat("\nS+ =", total_n, "| n_bar =", m_bar, "\n")
