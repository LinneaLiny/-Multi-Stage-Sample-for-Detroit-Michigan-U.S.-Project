#Data Acquisition and Cleansing
```{r}
bg_data_raw <- get_decennial(
  geography = "block group",
  table = "P12", # 性别与年龄表
  year = 2020,
  sumfile = "dhc",
  state = "MI",
  county = "Wayne",
  output = "wide"
)

# 
# 将 12 位的 BG GEOID 转换为 11 位的 Tract GEOID 以便匹配
detroit_frame <- bg_data_raw %>%
  mutate(Tract_GEOID = substr(GEOID, 1, 11)) %>%
  # 仅保留在上传的 CSV 文件中出现的底特律 Tract
  inner_join(TractFIPS, by = c("Tract_GEOID" = "GEOID"))
```
